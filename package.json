{
  "name": "helicarrier",
  "private": true,
  "description": "Governance platform for enterprise application creation",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @helicarrier/db generate",
    "db:migrate": "pnpm --filter @helicarrier/db migrate",
    "db:seed": "pnpm --filter @helicarrier/db seed",
    "db:studio": "pnpm --filter @helicarrier/db studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
